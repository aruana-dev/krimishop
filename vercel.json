{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "fall01.krimi.shop" }],
      "destination": "/faelle/fall01/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/faelle/fall01/$1"
    }
  ]
}
